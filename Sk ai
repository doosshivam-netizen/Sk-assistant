<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>SK AI — Your Smart Assistant</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #070710;
  --surface: #0d0d1a;
  --card: #12121f;
  --card2: #1a1a2e;
  --border: #1e1e35;
  --border2: #2a2a45;
  --cyan: #00d4ff;
  --purple: #7b2fff;
  --pink: #ff2d78;
  --green: #00ff88;
  --yellow: #ffcc00;
  --text: #e8e8ff;
  --muted: #6a6a9a;
  --muted2: #4a4a7a;
  --font: 'Rajdhani', sans-serif;
  --font-mono: 'Share Tech Mono', monospace;
  --font-display: 'Orbitron', sans-serif;
  --glow-cyan: 0 0 20px #00d4ff44, 0 0 40px #00d4ff22;
  --glow-purple: 0 0 20px #7b2fff44, 0 0 40px #7b2fff22;
  --sidebar-w: 260px;
  --radius: 14px;
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; overflow: hidden; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 15px;
  display: flex;
  position: relative;
}
body::before {
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(ellipse at 10% 20%, #7b2fff0a 0%, transparent 50%),
    radial-gradient(ellipse at 90% 80%, #00d4ff08 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, #ff2d780a 0%, transparent 70%);
  pointer-events:none;
  z-index:0;
}

/* SIDEBAR */
.sidebar {
  width: var(--sidebar-w);
  height: 100vh;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  position: fixed;
  left: 0; top: 0;
  z-index: 100;
  transform: translateX(-100%);
  transition: transform 0.3s cubic-bezier(.4,0,.2,1);
}
.sidebar.open { transform: translateX(0); }
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: #00000088;
  z-index: 99;
  backdrop-filter: blur(2px);
}
.sidebar-overlay.show { display: block; }
.sidebar-header {
  padding: 20px 16px 12px;
  border-bottom: 1px solid var(--border);
}
.sidebar-logo {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 900;
  background: linear-gradient(90deg, var(--cyan), var(--purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2px;
}
.sidebar-tagline {
  font-size: 10px;
  color: var(--muted);
  font-family: var(--font-mono);
  letter-spacing: 1.5px;
  margin-top: 2px;
}
.new-chat-btn {
  margin: 12px;
  padding: 10px;
  background: linear-gradient(135deg, var(--cyan)22, var(--purple)22);
  border: 1px solid var(--cyan)44;
  border-radius: var(--radius);
  color: var(--cyan);
  font-family: var(--font);
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  letter-spacing: 1px;
  transition: all 0.2s;
}
.new-chat-btn:hover { background: linear-gradient(135deg, var(--cyan)33, var(--purple)33); box-shadow: var(--glow-cyan); }
.sidebar-section {
  padding: 8px 12px 4px;
  font-size: 10px;
  color: var(--muted2);
  font-family: var(--font-mono);
  letter-spacing: 2px;
  text-transform: uppercase;
}
.chat-list {
  flex: 1;
  overflow-y: auto;
  padding: 4px 8px;
  scrollbar-width: thin;
  scrollbar-color: var(--border2) transparent;
}
.chat-item {
  padding: 9px 10px;
  border-radius: 10px;
  cursor: pointer;
  font-size: 13px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 8px;
  transition: all 0.15s;
  margin-bottom: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.chat-item:hover, .chat-item.active { background: var(--card2); color: var(--text); }
.chat-item .del-btn {
  margin-left: auto;
  opacity: 0;
  font-size: 14px;
  flex-shrink: 0;
  background: none;
  border: none;
  color: var(--pink);
  cursor: pointer;
  padding: 2px 4px;
}
.chat-item:hover .del-btn { opacity: 1; }
.sidebar-nav {
  padding: 8px;
  border-top: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.nav-item {
  padding: 10px 12px;
  border-radius: 10px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.15s;
}
.nav-item:hover { background: var(--card2); color: var(--text); }

/* MAIN */
.main {
  flex: 1;
  margin-left: 0;
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  z-index: 1;
}

/* TOPBAR */
.topbar {
  height: 56px;
  background: var(--surface)cc;
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 12px;
  gap: 10px;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}
.menu-btn {
  width: 36px; height: 36px;
  border-radius: 10px;
  border: 1px solid var(--border2);
  background: var(--card);
  color: var(--text);
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}
.menu-btn:hover { border-color: var(--cyan); color: var(--cyan); }
.topbar-title {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  background: linear-gradient(90deg, var(--cyan), var(--purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2px;
}
.model-badge {
  margin-left: auto;
  background: var(--card2);
  border: 1px solid var(--border2);
  border-radius: 20px;
  padding: 4px 10px;
  font-size: 10px;
  font-family: var(--font-mono);
  color: var(--cyan);
  cursor: pointer;
  white-space: nowrap;
  overflow: hidden;
  max-width: 120px;
  text-overflow: ellipsis;
}
.topbar-actions { display: flex; gap: 6px; }
.icon-btn {
  width: 34px; height: 34px;
  border-radius: 10px;
  border: 1px solid var(--border2);
  background: var(--card);
  color: var(--muted);
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
}
.icon-btn:hover { border-color: var(--cyan); color: var(--cyan); }
.icon-btn.active { border-color: var(--green); color: var(--green); background: #00ff8811; }

/* CHAT */
.chat-wrap {
  flex: 1;
  overflow-y: auto;
  padding: 16px 12px 8px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  scrollbar-width: thin;
  scrollbar-color: var(--border2) transparent;
}

/* WELCOME */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 16px;
  text-align: center;
  animation: fadeUp 0.6s ease;
  padding: 20px;
}
@keyframes fadeUp {
  from { opacity:0; transform: translateY(20px); }
  to   { opacity:1; transform: translateY(0); }
}
.welcome-orb {
  width: 80px; height: 80px;
  border-radius: 50%;
  background: conic-gradient(from 0deg, var(--cyan), var(--purple), var(--pink), var(--cyan));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  animation: spin-orb 4s linear infinite, pulse-orb 2s ease-in-out infinite;
}
@keyframes spin-orb { from { filter: hue-rotate(0deg); } to { filter: hue-rotate(360deg); } }
@keyframes pulse-orb {
  0%,100% { box-shadow: 0 0 30px #00d4ff44, 0 0 60px #7b2fff22; }
  50% { box-shadow: 0 0 50px #00d4ff77, 0 0 100px #7b2fff44; }
}
.welcome-title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 900;
  background: linear-gradient(90deg, var(--cyan), var(--purple), var(--pink));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 3px;
}
.welcome-sub {
  color: var(--muted);
  font-size: 14px;
  font-weight: 600;
  max-width: 300px;
  line-height: 1.6;
}
.username-badge {
  background: var(--card2);
  border: 1px solid var(--border2);
  border-radius: 20px;
  padding: 6px 16px;
  font-size: 13px;
  font-weight: 700;
  color: var(--cyan);
}

/* LANG INDICATOR BADGE */
.lang-indicator {
  background: var(--card2);
  border: 1px solid var(--green)44;
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 11px;
  font-family: var(--font-mono);
  color: var(--green);
  display: flex;
  align-items: center;
  gap: 5px;
}

.suggestions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  width: 100%;
  max-width: 340px;
  margin-top: 8px;
}
.sug-btn {
  background: var(--card);
  border: 1px solid var(--border2);
  border-radius: 12px;
  padding: 10px 12px;
  text-align: left;
  cursor: pointer;
  transition: all 0.2s;
  font-family: var(--font);
}
.sug-btn:hover { border-color: var(--cyan); background: var(--card2); }
.sug-btn .sug-icon { font-size: 18px; margin-bottom: 4px; }
.sug-btn .sug-text { font-size: 12px; color: var(--muted); font-weight: 600; line-height: 1.3; }

/* MESSAGES */
.msg {
  display: flex;
  gap: 10px;
  animation: msgIn 0.3s ease;
  max-width: 100%;
}
@keyframes msgIn {
  from { opacity:0; transform: translateY(8px); }
  to   { opacity:1; transform: translateY(0); }
}
.msg.user { flex-direction: row-reverse; }
.msg-avatar {
  width: 34px; height: 34px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
  background: conic-gradient(from 0deg, var(--cyan), var(--purple), var(--cyan));
  box-shadow: var(--glow-cyan);
  animation: avatar-spin 8s linear infinite;
}
@keyframes avatar-spin { from { filter: hue-rotate(0deg); } to { filter: hue-rotate(360deg); } }
.msg.user .msg-avatar {
  background: var(--card2);
  border: 2px solid var(--border2);
  box-shadow: none;
  animation: none;
}
.msg-content { flex: 1; max-width: calc(100% - 44px); }
.msg-name {
  font-size: 11px;
  font-family: var(--font-mono);
  color: var(--cyan);
  margin-bottom: 4px;
  letter-spacing: 1px;
}
.msg.user .msg-name { text-align: right; color: var(--muted); }
.bubble {
  padding: 12px 14px;
  border-radius: 16px;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.65;
  word-break: break-word;
  white-space: pre-wrap;
}
.bubble.ai {
  background: var(--card);
  border: 1px solid var(--border2);
  border-left: 2px solid var(--cyan);
  color: var(--text);
}
.bubble.user {
  background: linear-gradient(135deg, var(--purple)22, var(--cyan)11);
  border: 1px solid var(--purple)44;
  color: var(--text);
  border-right: 2px solid var(--purple);
}
.bubble-actions {
  display: flex;
  gap: 6px;
  margin-top: 6px;
  flex-wrap: wrap;
}
.bubble-act-btn {
  background: none;
  border: none;
  color: var(--muted2);
  font-size: 12px;
  cursor: pointer;
  padding: 3px 6px;
  border-radius: 6px;
  font-family: var(--font-mono);
  transition: all 0.15s;
  display: flex;
  align-items: center;
  gap: 3px;
}
.bubble-act-btn:hover { color: var(--cyan); background: var(--card2); }
.upload-preview {
  max-width: 200px;
  max-height: 150px;
  border-radius: 10px;
  margin-bottom: 8px;
  border: 1px solid var(--border2);
  display: block;
}
.file-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--card2);
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 12px;
  font-family: var(--font-mono);
  color: var(--cyan);
  margin-bottom: 8px;
}

/* TYPING */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 12px 14px;
}
.typing-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  animation: tdot 1.2s infinite;
}
.typing-dot:nth-child(1) { background: var(--cyan); }
.typing-dot:nth-child(2) { background: var(--purple); animation-delay: 0.2s; }
.typing-dot:nth-child(3) { background: var(--pink); animation-delay: 0.4s; }
@keyframes tdot {
  0%,80%,100% { transform: scale(0.7); opacity: 0.4; }
  40% { transform: scale(1.2); opacity: 1; }
}

/* INPUT */
.input-section {
  padding: 8px 12px 12px;
  background: var(--surface)cc;
  backdrop-filter: blur(12px);
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}
.upload-strip {
  display: none;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  padding: 6px 10px;
  background: var(--card);
  border: 1px solid var(--border2);
  border-radius: 10px;
}
.upload-strip.show { display: flex; }
.upload-thumb {
  width: 40px; height: 40px;
  object-fit: cover;
  border-radius: 6px;
  border: 1px solid var(--border2);
}
.upload-info { flex: 1; font-size: 12px; color: var(--muted); font-family: var(--font-mono); }
.upload-remove { background: none; border: none; color: var(--pink); font-size: 18px; cursor: pointer; }
.input-row {
  display: flex;
  align-items: flex-end;
  gap: 8px;
  background: var(--card);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 6px 8px;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.input-row:focus-within {
  border-color: var(--cyan);
  box-shadow: 0 0 0 2px #00d4ff18;
}
.input-icon-btn {
  width: 32px; height: 32px;
  border-radius: 8px;
  border: none;
  background: transparent;
  color: var(--muted);
  font-size: 17px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
}
.input-icon-btn:hover { color: var(--cyan); background: var(--card2); }
.input-icon-btn.recording { color: var(--pink); animation: rec-pulse 1s infinite; }
@keyframes rec-pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
textarea#msgInput {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  font-weight: 500;
  resize: none;
  max-height: 120px;
  min-height: 36px;
  padding: 8px 0;
  line-height: 1.5;
}
textarea#msgInput::placeholder { color: var(--muted2); }
.send-btn {
  width: 36px; height: 36px;
  border-radius: 10px;
  border: none;
  background: linear-gradient(135deg, var(--cyan), var(--purple));
  color: white;
  font-size: 17px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
  box-shadow: var(--glow-cyan);
}
.send-btn:hover { transform: scale(1.08); }
.send-btn:active { transform: scale(0.94); }
.send-btn:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }
.input-hint {
  text-align: center;
  font-size: 10px;
  color: var(--muted2);
  font-family: var(--font-mono);
  margin-top: 6px;
  letter-spacing: 0.5px;
}

/* PANELS */
.panel {
  display: none;
  position: fixed;
  inset: 0;
  background: #00000099;
  z-index: 200;
  align-items: flex-end;
  justify-content: center;
}
.panel.show { display: flex; }
.panel-box {
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 20px 20px 0 0;
  width: 100%;
  max-width: 480px;
  max-height: 85vh;
  overflow-y: auto;
  animation: slideUp 0.3s cubic-bezier(.4,0,.2,1);
  scrollbar-width: thin;
  scrollbar-color: var(--border2) transparent;
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.panel-header {
  padding: 16px 20px 12px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  background: var(--surface);
  z-index: 1;
}
.panel-title {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  color: var(--cyan);
  letter-spacing: 2px;
}
.panel-close {
  width: 30px; height: 30px;
  border-radius: 8px;
  border: 1px solid var(--border2);
  background: var(--card);
  color: var(--muted);
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.panel-body { padding: 16px 20px 24px; }

/* Settings */
.setting-group { margin-bottom: 20px; }
.setting-label {
  font-size: 11px;
  font-family: var(--font-mono);
  color: var(--muted);
  letter-spacing: 2px;
  margin-bottom: 8px;
  text-transform: uppercase;
}
.setting-input {
  width: 100%;
  background: var(--card);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 10px 14px;
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
}
.setting-input:focus { border-color: var(--cyan); }
select.setting-input option { background: var(--card2); }
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
.setting-row:last-child { border-bottom: none; }
.setting-row-label { font-size: 14px; font-weight: 600; }
.setting-row-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
.toggle {
  width: 44px; height: 24px;
  background: var(--border2);
  border-radius: 12px;
  position: relative;
  cursor: pointer;
  transition: background 0.2s;
  flex-shrink: 0;
}
.toggle.on { background: var(--cyan); }
.toggle::after {
  content: '';
  position: absolute;
  width: 18px; height: 18px;
  background: white;
  border-radius: 50%;
  top: 3px; left: 3px;
  transition: transform 0.2s;
  box-shadow: 0 1px 4px #0004;
}
.toggle.on::after { transform: translateX(20px); }
.save-btn {
  width: 100%;
  padding: 12px;
  background: linear-gradient(135deg, var(--cyan), var(--purple));
  border: none;
  border-radius: 12px;
  color: white;
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 2px;
  cursor: pointer;
  margin-top: 8px;
  box-shadow: var(--glow-cyan);
  transition: all 0.2s;
}
.save-btn:hover { transform: translateY(-1px); }

/* Memory */
.memory-item {
  background: var(--card);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 10px 12px;
  margin-bottom: 8px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13px;
  font-weight: 600;
}
.mem-icon { color: var(--yellow); flex-shrink: 0; }
.mem-text { flex: 1; line-height: 1.4; }
.mem-del { color: var(--pink); cursor: pointer; font-size: 16px; flex-shrink: 0; background: none; border: none; }
.mem-add { display: flex; gap: 8px; margin-top: 12px; }
.mem-input {
  flex: 1;
  background: var(--card);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 8px 12px;
  color: var(--text);
  font-family: var(--font);
  font-size: 13px;
  outline: none;
}
.mem-input:focus { border-color: var(--cyan); }
.mem-save-btn {
  padding: 8px 14px;
  background: var(--cyan)22;
  border: 1px solid var(--cyan)44;
  border-radius: 10px;
  color: var(--cyan);
  font-family: var(--font);
  font-weight: 700;
  cursor: pointer;
  font-size: 13px;
}

/* Model picker */
.model-list { display: flex; flex-direction: column; gap: 6px; }
.model-item {
  background: var(--card);
