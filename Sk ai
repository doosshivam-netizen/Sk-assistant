// ===== AUTO LANGUAGE DETECTION (JS side) =====
function detectScriptLang(text) {
  if (!text || text.trim().length === 0) return null;
  const scripts = [
    { re: /[\u0900-\u097F]/, lang: 'hi', name: 'Hindi' },
    { re: /[\u0A80-\u0AFF]/, lang: 'gu', name: 'Gujarati' },
    { re: /[\u0B80-\u0BFF]/, lang: 'ta', name: 'Tamil' },
    { re: /[\u0C00-\u0C7F]/, lang: 'te', name: 'Telugu' },
    { re: /[\u0C80-\u0CFF]/, lang: 'kn', name: 'Kannada' },
    { re: /[\u0D00-\u0D7F]/, lang: 'ml', name: 'Malayalam' },
    { re: /[\u0980-\u09FF]/, lang: 'bn', name: 'Bengali' },
    { re: /[\u0A00-\u0A7F]/, lang: 'pa', name: 'Punjabi' },
    { re: /[\u0B00-\u0B7F]/, lang: 'or', name: 'Odia' },
    { re: /[\u0600-\u06FF]/, lang: 'ur', name: 'Urdu' },
    { re: /[\u4E00-\u9FFF]/, lang: 'zh', name: 'Chinese' },
    { re: /[\u3040-\u30FF]/, lang: 'ja', name: 'Japanese' },
    { re: /[\uAC00-\uD7AF]/, lang: 'ko', name: 'Korean' },
    { re: /[\u0400-\u04FF]/, lang: 'ru', name: 'Russian' },
    { re: /[\u0370-\u03FF]/, lang: 'el', name: 'Greek' },
    { re: /[\u0600-\u06FF]/, lang: 'ar', name: 'Arabic' },
  ];
  for (const s of scripts) {
    if (s.re.test(text)) return s;
  }
  // Latin — could be Hindi transliterated (Hinglish), English, etc.
  // Check for common Hinglish/Hindi romanization words
  const hinglishWords = ['kya','hai','hoon','mein','karo','nahi','toh','aur','bhi','kuch','tera','mera','yaar','bhai','dost','accha','theek','haan','nahi','matlab','matlab','phir','abhi','sirf','kyun','kaise','kaisa','kaisi','tumhara','apna','unka'];
  const lower = text.toLowerCase();
  const words = lower.split(/\s+/);
  const hinglishCount = words.filter(w => hinglishWords.includes(w)).length;
  if (hinglishCount >= 1) return { lang: 'hi-roman', name: 'Hinglish' };
  return { lang: 'en', name: 'English' };
}

// TTS language mapping
function ttsLang(langCode) {
  const map = {
    'hi': 'hi-IN', 'hi-roman': 'hi-IN', 'gu': 'gu-IN',
    'ta': 'ta-IN', 'te': 'te-IN', 'kn': 'kn-IN',
    'ml': 'ml-IN', 'bn': 'bn-IN', 'pa': 'pa-IN',
    'ur': 'ur-PK', 'zh': 'zh-CN', 'ja': 'ja-JP',
    'ko': 'ko-KR', 'ru': 'ru-RU', 'el': 'el-GR',
    'ar': 'ar-SA', 'en': 'en-US', 'or': 'en-US',
  };
  return map[langCode] || 'en-US';
}

// ===== SYSTEM PROMPT BUILDER =====
// This is the CORE — ultra-strong language detection instruction
function buildSystemPrompt(personality, memories) {
  const PERSONALITIES = {
    friendly: `Tu SK AI hai — ek smart, helpful aur friendly AI assistant.`,
    professional: `Tu SK AI hai — ek professional AI assistant. Clear, precise aur structured answers deta hai.`,
    funny: `Tu SK AI hai — ek funny aur casual AI dost. Har response mein thoda humor hota hai.`,
    mentor: `Tu SK AI hai — ek wise teacher aur mentor. Patiently explain karta hai, examples deta hai.`,
    savage: `Tu SK AI hai — ek savage roaster jo sach bolta hai. Honest aur brutally funny answers deta hai.`,
  };

  const base = PERSONALITIES[personality] || PERSONALITIES.friendly;

  const memBlock = memories && memories.length > 0
    ? `\n\n=== USER KE BAARE MEIN MEMORIES ===\n${memories.map((m,i)=>`${i+1}. ${m}`).join('\n')}\n===`
    : '';

  // CRITICAL language rule — the most important part
  const langRule = `

=== SABSE IMPORTANT RULE: AUTO LANGUAGE DETECTION ===

Tu ek multilingual AI hai. Tera SABSE PEHLA kaam hai: user ne kis bhasha mein likha, woh detect karna aur USI BHASHA MEIN JAWAB DENA.

RULES (koi exception nahi):
1. User Hindi mein likhe (Devanagari: नमस्ते) → Tu Hindi mein jawab de
2. User English mein likhe → Tu English mein jawab de  
3. User Hinglish mein likhe (Roman Hindi: "bhai kya kar raha hai") → Tu Hinglish mein jawab de
4. User Gujarati mein likhe → Tu Gujarati mein jawab de
5. User Tamil mein likhe → Tu Tamil mein jawab de
6. User Bengali mein likhe → Tu Bengali mein jawab de
7. User Marathi mein likhe → Tu Marathi mein jawab de
8. User Punjabi mein likhe → Tu Punjabi mein jawab de
9. User Urdu mein likhe → Tu Urdu mein jawab de
10. User kisi bhi aur language mein likhe → usi language mein jawab de

KABHI MAT KARNA:
- Kabhi khud language choose mat kar
- Kabhi Hindi mein jawab mat de jab user English mein likh raha ho
- Kabhi English mein jawab mat de jab user Hindi/Hinglish mein likh raha ho
- Beech conversation mein language mat badal jab tak user khud na badle
- Pehle detect karo, phir jawab do — yeh ek second ka kaam hai

HINGLISH detection tip: Agar text Roman script mein hai lekin Hindi ke words hain (yaar, bhai, kya, hai, nahi, toh, aur, karo, dost, etc.) → Hinglish hai → Hinglish mein jawab de.

YEH RULE SABSE IMPORTANT HAI — PERSONALITY SE BHI ZYADA.
=================================================`;

  return base + memBlock + langRule;
}

// ===== STATE =====
let state = {
  apiKey: '',
  model: 'openai/gpt-4o-mini',
  userName: 'Guest',
  personality: 'friendly',
  tts: false,
  web: false,
  mem: true,
  chats: {},
  currentChat: null,
  memories: [],
};

let isLoading = false;
let recognition = null;
let isTTSOn = false;
let isRecording = false;
let uploadedFile = null;
let uploadedB64 = null;
let uploadedType = null;

function loadState() {
  const s = localStorage.getItem('sk_ai_state_v2');
  if (s) { try { Object.assign(state, JSON.parse(s)); } catch(e){} }
}

function saveState() {
  localStorage.setItem('sk_ai_state_v2', JSON.stringify(state));
}

function init() {
  loadState();
  renderChatList();
  renderMemory();
  renderModels();
  updateUI();
  document.getElementById('setName').value = state.userName;
  document.getElementById('setApiKey').value = state.apiKey;
  document.getElementById('setPersonality').value = state.personality;
  syncToggles();
}

function updateUI() {
  document.getElementById('welcomeBadge').textContent = `👤 ${state.userName}`;
  const m = MODELS.find(x => x.id === state.model);
  document.getElementById('modelBadge').textContent = m ? m.name : state.model.split('/')[1];
  isTTSOn = state.tts;
  if (isTTSOn) document.getElementById('speakToggle').classList.add('active');
  else document.getElementById('speakToggle').classList.remove('active');
  if (state.web) document.getElementById('webBtn').classList.add('web-on');
  else document.getElementById('webBtn').classList.remove('web-on');
}

function syncToggles() {
  ['tts','web','mem'].forEach(k => {
    const el = document.getElementById(k+'Toggle');
    if (el) el.className = 'toggle' + (state[k] ? ' on' : '');
  });
}

// ===== SIDEBAR =====
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('show');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
}

// ===== CHAT MANAGEMENT =====
function newChat() {
  const id = 'chat_' + Date.now();
  state.chats[id] = { title: 'New Chat', messages: [] };
  state.currentChat = id;
  saveState();
  renderChatList();
  clearChatUI();
  closeSidebar();
}

function loadChat(id) {
  state.currentChat = id;
  saveState();
  clearChatUI();
  const chat = state.chats[id];
  if (chat && chat.messages.length > 0) {
    document.getElementById('welcomeScreen')?.remove();
    chat.messages.forEach(m => appendMsg(m.role, m.content, m.imgB64, m.imgType, m.fileName, false));
  }
  closeSidebar();
}

function deleteChat(id, e) {
  e.stopPropagation();
  delete state.chats[id];
  if (state.currentChat === id) { state.currentChat = null; clearChatUI(); }
  saveState();
  renderChatList();
}

function clearChatUI() {
  document.getElementById('chatWrap').innerHTML = `
    <div class="welcome" id="welcomeScreen">
      <div class="welcome-orb">⚡</div>
      <div class="welcome-title">SK AI</div>
      <div class="welcome-sub">Kisi bhi bhasha mein baat karo — main automatically samjhunga!</div>
      <div class="username-badge">👤 ${state.userName}</div>
      <div class="lang-indicator">🌐 Auto Language Detection ON</div>
      <div class="suggestions">
        <button class="sug-btn" onclick="quickSend('Mujhe Python code likhna sikha')">
          <div class="sug-icon">💻</div><div class="sug-text">Code sikhao</div>
        </button>
        <button class="sug-btn" onclick="quickSend('What is machine learning?')">
          <div class="sug-icon">🤖</div><div class="sug-text">Ask in English</div>
        </button>
        <button class="sug-btn" onclick="quickSend('Ek creative story likho')">
          <div class="sug-icon">✍️</div><div class="sug-text">Story likhao</div>
        </button>
        <button class="sug-btn" onclick="quickSend('Aaj ke liye motivate karo')">
          <div class="sug-icon">💪</div><div class="sug-text">Motivate karo</div>
        </button>
      </div>
    </div>`;
}

function renderChatList() {
  const el = document.getElementById('chatList');
  const ids = Object.keys(state.chats).reverse();
  if (ids.length === 0) {
    el.innerHTML = '<div style="padding:10px;font-size:12px;color:var(--muted2);text-align:center;font-family:var(--font-mono)">No chats yet</div>';
    return;
  }
  el.innerHTML = ids.map(id => {
    const c = state.chats[id];
    const active = id === state.currentChat ? ' active' : '';
    return `<div class="chat-item${active}" onclick="loadChat('${id}')">
      💬 <span style="flex:1;overflow:hidden;text-overflow:ellipsis">${c.title}</span>
      <button class="del-btn" onclick="deleteChat('${id}',event)">🗑</button>
    </div>`;
  }).join('');
}

function clearAll() {
  if (confirm('Sab chats delete kar dein?')) {
    state.chats = {};
    state.currentChat = null;
    saveState();
    renderChatList();
    clearChatUI();
    closeSidebar();
    toast('🗑️ Sab clear!');
  }
}

// ===== MESSAGES =====
function appendMsg(role, text, imgB64, imgType, fileName, save=true) {
  document.getElementById('welcomeScreen')?.remove();
  const wrap = document.getElementById('chatWrap');
  const div = document.createElement('div');
  div.className = `msg ${role}`;

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.textContent = role === 'ai' ? '⚡' : (state.userName[0]?.toUpperCase() || '👤');

  const content = document.createElement('div');
  content.className = 'msg-content';

  const name = document.createElement('div');
  name.className = 'msg-name';
  name.textContent = role === 'ai' ? 'SK AI' : state.userName;

  const bubble = document.createElement('div');
  bubble.className = `bubble ${role}`;

  if (imgB64 && role === 'user') {
    const img = document.createElement('img');
    img.className = 'upload-preview';
    img.src = `data:${imgType};base64,${imgB64}`;
    bubble.appendChild(img);
  }

  if (fileName && role === 'user') {
    const fb = document.createElement('div');
    fb.className = 'file-badge';
    fb.textContent = `📎 ${fileName}`;
    bubble.appendChild(fb);
  }

  bubble.appendChild(document.createTextNode(text));

  if (role === 'ai') {
    const acts = document.createElement('div');
    acts.className = 'bubble-actions';

    const copyBtn = document.createElement('button');
    copyBtn.className = 'bubble-act-btn';
    copyBtn.textContent = '📋 Copy';
    copyBtn.onclick = () => { navigator.clipboard.writeText(text); toast('✅ Copied!'); };

    const speakBtn = document.createElement('button');
    speakBtn.className = 'bubble-act-btn';
    speakBtn.textContent = '🔊 Listen';
    speakBtn.onclick = () => speak(text);

    acts.appendChild(copyBtn);
    acts.appendChild(speakBtn);
    bubble.appendChild(acts);
  }

  content.appendChild(name);
  content.appendChild(bubble);
  div.appendChild(avatar);
  div.appendChild(content);
  wrap.appendChild(div);
  wrap.scrollTop = wrap.scrollHeight;

  if (save && state.currentChat) {
    state.chats[state.currentChat].messages.push({ role, content: text, imgB64, imgType, fileName });
    const msgs = state.chats[state.currentChat].messages;
    if (msgs.length === 1 && role === 'user') {
      state.chats[state.currentChat].title = text.slice(0, 30) + (text.length > 30 ? '...' : '');
      renderChatList();
    }
    saveState();
  }
}

function addTyping() {
  document.getElementById('welcomeScreen')?.remove();
  const wrap = document.getElementById('chatWrap');
  const div = document.createElement('div');
  div.className = 'msg ai';
  div.id = 'typingMsg';
  div.innerHTML = `
    <div class="msg-avatar">⚡</div>
    <div class="msg-content">
      <div class="msg-name">SK AI</div>
      <div class="bubble ai typing-indicator">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    </div>`;
  wrap.appendChild(div);
  wrap.scrollTop = wrap.scrollHeight;
}

function removeTyping() {
  document.getElementById('typingMsg')?.remove();
}

// ===== SEND =====
async function sendMsg() {
  if (isLoading) return;
  const inp = document.getElementById('msgInput');
  const text = inp.value.trim();
  if (!text && !uploadedFile) return;

  if (!state.apiKey) {
    toast('⚠️ API Key set karo pehle!');
    openPanel('settingsPanel');
    return;
  }

  if (!state.currentChat) {
    const id = 'chat_' + Date.now();
    state.chats[id] = { title: 'New Chat', messages: [] };
    state.currentChat = id;
  }

  const userText = text || '(File uploaded)';
  inp.value = '';
  inp.style.height = 'auto';
  isLoading = true;
  document.getElementById('sendBtn').disabled = true;

  const b64 = uploadedB64;
  const mtype = uploadedType;
  const fname = uploadedFile?.name;
  appendMsg('user', userText, b64, mtype, fname);
  removeUpload();
  addTyping();

  // Detect language of user message
  const detectedLang = detectScriptLang(userText);

  try {
    const history = state.chats[state.currentChat].messages
      .slice(-20)
      .map(m => {
        if (m.imgB64) {
          return {
            role: m.role === 'ai' ? 'assistant' : 'user',
            content: [
              { type: 'image_url', image_url: { url: `data:${m.imgType};base64,${m.imgB64}` } },
              { type: 'text', text: m.content }
            ]
          };
        }
        return { role: m.role === 'ai' ? 'assistant' : 'user', content: m.content };
      });

    // Build system prompt with auto-language detection rules
    const systemPrompt = buildSystemPrompt(state.personality, state.mem ? state.memories : []);

    // Web search
    let webContext = '';
    if (state.web && text) webContext = await doWebSearch(text);

    // Add explicit language instruction to THIS message
    let langInstruction = '';
    if (detectedLang) {
      if (detectedLang.lang === 'en') {
        langInstruction = `[DETECTED LANGUAGE: English — Reply in English only]`;
      } else if (detectedLang.lang === 'hi' || detectedLang.lang === 'hi-roman') {
        langInstruction = `[DETECTED LANGUAGE: ${detectedLang.name} — Reply in ${detectedLang.name} only]`;
      } else {
        langInstruction = `[DETECTED LANGUAGE: ${detectedLang.name} — Reply in ${detectedLang.name} only]`;
      }
    }

    const finalMsg = [
      langInstruction,
      webContext ? `[Web Search Results]\n${webContext}` : '',
      userText
    ].filter(Boolean).join('\n\n');

    const msgs = [...history.slice(0, -1)];
    if (b64) {
      msgs.push({
        role: 'user',
        content: [
          { type: 'image_url', image_url: { url: `data:${mtype};base64,${b64}` } },
          { type: 'text', text: finalMsg }
        ]
      });
    } else {
      msgs.push({ role: 'user', content: finalMsg });
    }

    const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${state.apiKey}`,
        'Content-Type': 'application/json',
        'HTTP-Referer': 'https://sk-ai.app',
        'X-Title': 'SK AI Assistant'
      },
      body: JSON.stringify({
        model: state.model,
        messages: [{ role: 'system', content: systemPrompt }, ...msgs],
        max_tokens: 1500,
        temperature: 0.8
      })
    });

    const data = await res.json();
    if (data.error) throw new Error(data.error.message);

    const reply = data.choices?.[0]?.message?.content || 'Kuch toh hua bhai, try again!';
    removeTyping();
    appendMsg('ai', reply);

    if (state.mem) autoExtractMemory(userText, reply);

    if (isTTSOn) {
      // Use detected language for TTS
      speakWithLang(reply, detectedLang?.lang || 'en');
    }

  } catch(err) {
    removeTyping();
    appendMsg('ai', `⚠️ Error: ${err.message}\n\nAPI key check karo ya model change karo.`);
  }

  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
  document.getElementById('msgInput').focus();
}

async function doWebSearch(query) {
  try {
    const res = await fetch(`https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json&no_html=1&skip_disambig=1`);
    const data = await res.json();
    let results = '';
    if (data.AbstractText) results += `Summary: ${data.AbstractText}\n`;
    if (data.RelatedTopics) {
      data.RelatedTopics.slice(0, 4).forEach(t => { if (t.Text) results += `- ${t.Text}\n`; });
    }
    return results || '';
  } catch(e) { return ''; }
}

function autoExtractMemory(userMsg, aiReply) {
  const keywords = ['mera naam','i am','main hoon','mujhe pasand','i like','i work','main kaam','my name','meri age','i study'];
  const lower = userMsg.toLowerCase();
  if (keywords.some(k => lower.includes(k))) {
    const mem = userMsg.slice(0, 80);
    if (!state.memories.includes(mem)) {
      state.memories.push(mem);
      if (state.memories.length > 20) state.memories.shift();
      saveState();
      renderMemory();
    }
  }
}

function quickSend(text) {
  document.getElementById('msgInput').value = text;
  sendMsg();
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

// ===== FILE UPLOAD =====
function handleFile(input) {
  const file = input.files[0];
  if (!file) return;
  uploadedFile = file;
  const reader = new FileReader();
  reader.onload = e => {
    uploadedB64 = e.target.result.split(',')[1];
    uploadedType = file.type;
    const strip = document.getElementById('uploadStrip');
    strip.classList.add('show');
    document.getElementById('uploadInfo').textContent = file.name;
    if (file.type.startsWith('image/')) {
      document.getElementById('uploadThumb').src = e.target.result;
      document.getElementById('uploadThumb').style.display = 'block';
    } else {
      document.getElementById('uploadThumb').style.display = 'none';
    }
  };
  reader.readAsDataURL(file);
  input.value = '';
}

function removeUpload() {
  uploadedFile = null; uploadedB64 = null; uploadedType = null;
  document.getElementById('uploadStrip').classList.remove('show');
  document.getElementById('uploadThumb').src = '';
}

// ===== VOICE INPUT =====
function toggleVoice() {
  if (!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)) {
    toast('❌ Voice not supported in this browser'); return;
  }
  if (isRecording) { recognition?.stop(); return; }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SR();
  // NO lang set = browser auto-detects whatever language user speaks
  recognition.lang = '';
  recognition.interimResults = false;
  recognition.continuous = false;
  recognition.onstart = () => {
    isRecording = true;
    document.getElementById('micBtn').classList.add('recording');
    document.getElementById('micBtn').textContent = '⏹️';
    toast('🎤 Koi bhi bhasha mein bolo...');
  };
  recognition.onresult = e => {
    const t = e.results[0][0].transcript;
    document.getElementById('msgInput').value = t;
    autoResize(document.getElementById('msgInput'));
    toast(`🌐 Detected: ${e.results[0][0].transcript.slice(0,30)}...`);
  };
  recognition.onend = () => {
    isRecording = false;
    document.getElementById('micBtn').classList.remove('recording');
    document.getElementById('micBtn').textContent = '🎤';
  };
  recognition.onerror = () => {
    isRecording = false;
    document.getElementById('micBtn').classList.remove('recording');
    document.getElementById('micBtn').textContent = '🎤';
  };
  recognition.start();
}

// ===== TTS =====
function speak(text) {
  if (!('speechSynthesis' in window)) return;
  window.speechSynthesis.cancel();
  const clean = text.replace(/[#*`_[\]]/g, '');
  const detected = detectScriptLang(clean);
  const utt = new SpeechSynthesisUtterance(clean);
  utt.lang = ttsLang(detected?.lang || 'en');
  utt.rate = 0.95;
  utt.pitch = 1;
  window.speechSynthesis.speak(utt);
}

function speakWithLang(text, langCode) {
  if (!('speechSynthesis' in window)) return;
  window.speechSynthesis.cancel();
  const clean = text.replace(/[#*`_[\]]/g, '');
  const utt = new SpeechSynthesisUtterance(clean);
  utt.lang = ttsLang(langCode);
  utt.rate = 0.95;
  window.speechSynthesis.speak(utt);
}

function toggleTTS() {
  isTTSOn = !isTTSOn;
  state.tts = isTTSOn;
  saveState();
  const btn = document.getElementById('speakToggle');
  if (isTTSOn) { btn.classList.add('active'); toast('🔊 Voice ON'); }
  else { btn.classList.remove('active'); window.speechSynthesis?.cancel(); toast('🔇 Voice OFF'); }
}

// ===== WEB SEARCH =====
function toggleWeb() {
  state.web = !state.web;
  saveState();
  if (state.web) { document.getElementById('webBtn').classList.add('web-on'); toast('🌐 Web Search ON'); }
  else { document.getElementById('webBtn').classList.remove('web-on'); toast('🌐 Web Search OFF'); }
  syncToggles();
}

// ===== MEMORY =====
function renderMemory() {
  const el = document.getElementById('memoryList');
  if (!el) return;
  if (state.memories.length === 0) {
    el.innerHTML = '<div style="text-align:center;color:var(--muted2);font-size:13px;padding:20px;font-family:var(--font-mono)">Abhi koi memory nahi hai</div>';
    return;
  }
  el.innerHTML = state.memories.map((m, i) => `
    <div class="memory-item">
      <span class="mem-icon">🧠</span>
      <span class="mem-text">${m}</span>
      <button class="mem-del" onclick="delMemory(${i})">✕</button>
    </div>`).join('');
}

function addMemory() {
  const inp = document.getElementById('memInput');
  const val = inp.value.trim();
  if (!val) return;
  state.memories.push(val);
  inp.value = '';
  saveState();
  renderMemory();
  toast('🧠 Memory saved!');
}

function delMemory(i) {
  state.memories.splice(i, 1);
  saveState();
  renderMemory();
}

// ===== MODELS =====
function renderModels() {
  const el = document.getElementById('modelList');
  if (!el) return;
  el.innerHTML = MODELS.map(m => `
    <div class="model-item ${m.id === state.model ? 'selected' : ''}" onclick="selectModel('${m.id}')">
      <div>
        <div class="model-name">${m.name}</div>
        <div class="model-sub">${m.sub}</div>
      </div>
      <div class="model-check">✓</div>
    </div>`).join('');
}

function selectModel(id) {
  state.model = id;
  saveState();
  renderModels();
  const m = MODELS.find(x => x.id === id);
  document.getElementById('modelBadge').textContent = m ? m.name : id.split('/')[1];
  closePanel('modelPanel');
  toast(`🤖 Model: ${m?.name}`);
}

// ===== SETTINGS =====
function toggleSetting(key) {
  state[key] = !state[key];
  syncToggles();
  if (key === 'web') {
    if (state.web) document.getElementById('webBtn').classList.add('web-on');
    else document.getElementById('webBtn').classList.remove('web-on');
  }
}

function saveSettings() {
  state.userName = document.getElementById('setName').value.trim() || 'Guest';
  state.apiKey = document.getElementById('setApiKey').value.trim();
  state.personality = document.getElementById('setPersonality').value;
  saveState();
  updateUI();
  closePanel('settingsPanel');
  toast('✅ Settings saved!');
}

// ===== PANELS =====
function openPanel(id) {
  if (id === 'memoryPanel') renderMemory();
  if (id === 'modelPanel') renderModels();
  if (id === 'settingsPanel') {
    document.getElementById('setName').value = state.userName;
    document.getElementById('setApiKey').value = state.apiKey;
    document.getElementById('setPersonality').value = state.personality;
    syncToggles();
  }
  document.getElementById(id).classList.add('show');
}

function closePanel(id) {
  document.getElementById(id).classList.remove('show');
}

function panelBg(e, id) {
  if (e.target === document.getElementById(id)) closePanel(id);
}

// ===== TOAST =====
function toast(msg) {
  document.querySelectorAll('.toast').forEach(t => t.remove());
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 2500);
}

init();
</script>
